# --- Auth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar ---
# Use "primary" for the owner's main calendar, or paste a calendar ID.
OWNER_CALENDAR_ID=primary
# Optional: pre-issued refresh token for the owner Calendar account.
GOOGLE_REFRESH_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@sulceramic.com

# --- Owner ---
# The user with this email becomes role=OWNER on sign-in.
OWNER_EMAIL=miguel@sulceramic.com

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Prices are in cents.
# Book Sessions: charged after every 4 confirmed sessions (50 EUR/session = 200 EUR/block by default).
PRICE_PER_SESSION=5000
# Residency: charged upfront monthly (40 EUR/session by default).
PRICE_RESIDENCY_SESSION=4000

# --- Cron protection ---
CRON_SECRET=replace-with-random-string

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=file:./dev.db

# --- Demo Mode (for GitHub Pages static export) ---
NEXT_PUBLIC_DEMO_MODE=false
